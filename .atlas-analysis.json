{
  "projectType": "frontend",
  "projectName": "skyhan.cloud",
  "projectDescription": "The source code for Gökhan Bulut's personal portfolio website, built with Next.js 15 and Tailwind CSS, featuring a blog, project showcase, work history, and live Discord status integration.",
  "theme": "willow",
  "primaryColor": "#a86848",
  "lightColor": "#faf8f5",
  "darkColor": "#262422",
